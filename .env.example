# AI Container Orchestrator — 운영 환경 변수 예시
# 이 파일을 .env 로 복사한 뒤 필요한 값만 수정해서 사용하세요.
# Docker Compose 는 같은 디렉터리의 .env 를 자동으로 읽습니다.

# 서비스 상태(services.json, cluster.db)를 저장할 디렉터리
# Docker Compose 기본 설정에서는 /data 가 볼륨에 매핑되어 있어 재시작 후에도 유지됩니다.
ORCHESTRATOR_STATE_DIR=/data

# 노드 역할: master 또는 worker
# master: 클러스터 관리, 스케줄링, 마이그레이션 제어
# worker: 로컬 컨테이너 관리 + 마스터에 하트비트 전송
ORCHESTRATOR_ROLE=master

# (선택) /v1/* API 보호용 Bearer 토큰
# 설정하면 /v1/cluster/* 를 제외한 /v1/* 요청에 Authorization: Bearer <token> 이 필요합니다.
# ORCHESTRATOR_API_TOKEN=여기에_충분히_랜덤한_토큰_문자열

# === Worker 전용 설정 ===
# 마스터 노드 URL (worker 역할일 때 필수)
# ORCHESTRATOR_MASTER_URL=http://10.0.0.1:8000

# 이 노드의 이름 (기본: 호스트명)
# ORCHESTRATOR_NODE_NAME=node-a

# 하트비트 간격 (초, 기본: 10)
# ORCHESTRATOR_HEARTBEAT_INTERVAL=10
